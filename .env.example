# ─── PLOT 환경변수 템플릿 ────────────────────────────────────────────────────
# 이 파일을 복사해 .env.local 을 만들고 실제 값을 채우세요.
# .env.local 은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨).
#
# Vite 규칙: 브라우저에 노출되는 키는 반드시 VITE_ 접두사 필요.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kakao Map Web API ─────────────────────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# ── Firebase (Spark 무료 플랜) ────────────────────────────────────────────────
# Firebase 콘솔 → 프로젝트 설정 → 내 앱 → SDK 설정 및 구성
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ── Cloudflare R2 (이미지 업로드) ────────────────────────────────────────────
# R2 버킷의 퍼블릭 도메인 URL (Workers 또는 커스텀 도메인)
VITE_R2_BASE_URL=https://your-bucket.your-domain.com

# R2 업로드용 API 엔드포인트 (Cloudflare Worker URL)
# 주의: 이 값은 서버 측에서만 사용해야 하지만, Worker를 통해 간접 호출하므로 노출 가능
VITE_R2_UPLOAD_ENDPOINT=https://your-worker.your-subdomain.workers.dev/upload
