rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── 전역 핀 컬렉션 (지오 쿼리용) ────────────────────────────────────────
    match /pins/{pinId} {
      allow read: if true;
      // 인증 유저만 핀 생성/수정 — createPlot 서비스에서만 호출
      allow write: if isAuth();
    }

    // ── 플롯 컬렉션 ──────────────────────────────────────────────────────────
    match /plots/{plotId} {
      allow read: if resource.data.isPublic == true
                  || isOwner(resource.data.authorId);

      allow create: if isAuth()
                    && request.resource.data.authorId == request.auth.uid;

      // 작성자 전체 수정 OR 인증 유저의 scrapCount 단독 변경
      allow update: if isOwner(resource.data.authorId)
                    || (isAuth()
                        && request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['scrapCount']));

      allow delete: if isOwner(resource.data.authorId);

      // 핀 서브컬렉션
      match /pins/{pinId} {
        allow read: if true;
        // 플롯 작성자만 핀 생성/수정/삭제
        allow write: if isAuth()
                     && get(/databases/$(database)/documents/plots/$(plotId))
                          .data.authorId == request.auth.uid;

        // 핀 댓글 서브컬렉션
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isAuth()
                        && request.resource.data.authorId == request.auth.uid;
          allow delete: if isOwner(resource.data.authorId);
          allow update: if false;
        }
      }
    }

    // ── 유저 컬렉션 ──────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);

      // 본인 전체 수정 OR 타인의 followersCount 단독 변경 (팔로우 연산)
      allow update: if isOwner(uid)
                    || (isAuth()
                        && request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['followersCount']));

      allow delete: if isOwner(uid);

      // 스크랩 목록 — 본인만
      match /scraps/{plotId} {
        allow read, write: if isOwner(uid);
      }

      // 내가 팔로우하는 목록 — 본인만
      match /following/{targetUid} {
        allow read, write: if isOwner(uid);
      }

      // 나를 팔로우하는 목록 — 팔로워 본인이 자신의 항목만 write
      match /followers/{followerId} {
        allow read: if true;
        allow write: if isOwner(followerId);
      }
    }
  }
}
